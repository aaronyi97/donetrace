    "type": "git",
    "url": "git+https://github.com/aaronyi97/donetrace.git"
  },
  "bugs": {
    "url": "https://github.com/aaronyi97/donetrace/issues"
  },
  "homepage": "https://github.com/aaronyi97/donetrace#readme",
  "files": [
    ".aict",
    "bin",
    "docs",
    "scripts",
    "src",
    "tests",
    "README.md",
    "START_HERE.md",
